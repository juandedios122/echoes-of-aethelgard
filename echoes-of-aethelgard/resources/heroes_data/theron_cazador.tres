script = ExtResource("1")
hero_id = "theron_cazador"
hero_name = "Theron"
title = "El Rastreador"
lore_text = "Cazador experto criado en las profundidades del Bosque Susurrante. Theron nunca habla más de lo necesario, prefiere observar. Sus trampas son mortales y silenciosas, y ninguna presa ha conseguido escapar de él dos veces. Entre los Cazadores del Bosque, es conocido como La Sombra Verde."
