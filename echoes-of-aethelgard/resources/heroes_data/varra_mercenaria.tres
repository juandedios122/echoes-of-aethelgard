script = ExtResource("1")
hero_id = "varra_mercenaria"
hero_name = "Varra"
title = "La Mercenaria"
lore_text = "Sin lealtades ni causa, Varra lucha por quien pague más. O eso dice. En realidad, lleva años rechazando contratos contra los débiles y aceptando solo misiones que le parecen justas. Nunca lo admitiría, pero bajo esa armadura manchada de sangre late el corazón de alguien que aún cree en algo."
